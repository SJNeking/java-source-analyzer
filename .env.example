# ============================================================
# Environment Configuration Template
# Copy this file to .env and fill in your secrets
# NEVER commit the actual .env file to Git!
# ============================================================

# Database
DATABASE_URL=jdbc:postgresql://localhost:15432/codeguardian
DATABASE_USER=root
DATABASE_PASSWORD=123456

# Ollama
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:32b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (Optional)
OPENAI_API_KEY=sk-...
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4
OPENAI_EMBED_MODEL=text-embedding-3-small

# MinIO (Optional)
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_PUBLIC_URL=http://localhost:19000
